# Production Environment Variables for Film Loca App
# These will be injected by GitHub Actions during build

# Supabase Configuration
# VITE_SUPABASE_URL and VITE_SUPABASE_ANON_KEY will be set by GitHub Actions

# App Configuration
VITE_APP_NAME=Film Loca
VITE_APP_URL=https://filmloca.com

# Optional: Google Analytics (if you use it)
# VITE_GA_TRACKING_ID=your_ga_tracking_id

# Optional: Mapbox (if you use maps)
# VITE_MAPBOX_TOKEN=your_mapbox_token
